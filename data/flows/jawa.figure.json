let currentFlow = null;
let currentStep = null;

async function handleUserMessage(message) {
  const text = message.toLowerCase().trim();

  // START FLOW
  if (!currentFlow) {
    if (text.includes("jawa")) {
      currentFlow = await loadFlow("jawa.figure.json");
      currentStep = currentFlow.start;
      return currentFlow.steps[currentStep].content;
    }

    return fallback();
  }

  // CONTINUE FLOW
  const step = currentFlow.steps[currentStep];

  if (!step || !step.options) {
    resetFlow();
    return fallback();
  }

  // FIND MATCH
  for (const option of step.options) {
    for (const keyword of option.match) {
      if (text === keyword || text.includes(keyword)) {
        currentStep = option.next;
        const nextStep = currentFlow.steps[currentStep];

        if (!nextStep) {
          resetFlow();
          return fallback();
        }

        if (nextStep.end) {
          const response = nextStep.content;
          resetFlow();
          return response;
        }

        return nextStep.content;
      }
    }
  }

  // NO MATCH → STAY IN FLOW (IMPORTANT)
  return step.content;
}

function resetFlow() {
  currentFlow = null;
  currentStep = null;
}

function fallback() {
  return "Sorry, that’s outside my collector database.\n\nI focus on vintage Kenner Star Wars toys from 1977 to 1985.\n\nIf you meant a figure or accessory, tell me which one and I’ll guide you.";
}

async function loadFlow(file) {
  const res = await fetch(`/data/flows/${file}`);
  return await res.json();
}